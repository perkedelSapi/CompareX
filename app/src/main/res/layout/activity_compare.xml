<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_variant"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/text_primary"
        app:title="Perbandingan"
        app:titleTextColor="@color/text_primary"/>

    <!-- Skeleton loading state -->
    <include
        android:id="@+id/layout_skeleton"
        layout="@layout/layout_compare_skeleton"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Error -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
        <ImageView android:layout_width="64dp" android:layout_height="64dp"
            android:src="@android:drawable/ic_dialog_alert" android:tint="@color/status_below"/>
        <TextView android:id="@+id/tv_error" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="@string/msg_error_generic"
            android:textColor="@color/text_secondary" android:textSize="14sp"
            android:gravity="center" android:layout_marginTop="12dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_retry"
            style="@style/Widget.CompareX.Button.Outlined"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/btn_retry" android:layout_marginTop="12dp"/>
    </LinearLayout>

    <!-- ===== Scrollable main content ===== -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ============================================================
                 AI ANALYSIS CARD
                 ============================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/accent_dark"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ai_advisor"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ai_compare_subtitle"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/progress_ai"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:indeterminateTint="@color/accent"
                            android:layout_marginEnd="8dp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <!-- Spek user summary -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/primary_variant"
                        app:cardCornerRadius="8dp">
                        <TextView
                            android:id="@+id/tv_user_spek_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/label_your_spec"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:padding="10dp"
                            android:fontFamily="monospace"/>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Analyze button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ai_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/btn_ai_analysis"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        app:backgroundTint="@color/accent_dark"
                        app:cornerRadius="10dp"
                        app:icon="@null"/>

                    <!-- AI Result card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_ai_result"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@color/primary"
                        app:cardCornerRadius="10dp"
                        app:strokeColor="@color/surface_variant"
                        app:strokeWidth="1dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ai_result_header"
                                android:textColor="@color/accent"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/tv_anchor_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="10sp"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_marginBottom="8dp"
                                android:visibility="gone"/>

                            <TextView
                                android:id="@+id/tv_ai_result"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:lineSpacingMultiplier="1.6"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ============================================================
                 GAME HEADER ROW
                 ============================================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/table_header"
                android:paddingVertical="12dp"
                android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_col_spec" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_header_game1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Game 1" android:textColor="@color/accent" android:textSize="12sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/tv_header_game2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="Game 2" android:textColor="@color/status_enough" android:textSize="12sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- ============================================================
                 SECTION: GAME INFO
                 ============================================================ -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_section_header" android:paddingVertical="8dp" android:paddingHorizontal="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_game_info_section" android:textColor="@color/accent" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Developer" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_dev_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/tv_dev_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/label_release_short" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_date_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/tv_date_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Metacritic" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_meta_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/metacritic_green" android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/tv_meta_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/metacritic_green" android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Genre" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:id="@+id/tv_genre_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
                <TextView android:id="@+id/tv_genre_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="—" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- ============================================================
                 SECTION: MINIMUM REQUIREMENTS
                 ============================================================ -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_section_header" android:paddingVertical="8dp" android:paddingHorizontal="12dp" android:layout_marginTop="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_min_req" android:textColor="@color/accent" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="OS" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_os_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_os_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Processor" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_proc_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_proc_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Memory" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_mem_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_mem_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Graphics" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_gfx_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_gfx_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DirectX" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_dx_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_dx_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Storage" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_min_store_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_min_store_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>

            <!-- ============================================================
                 SECTION: RECOMMENDED REQUIREMENTS
                 ============================================================ -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_section_header" android:paddingVertical="8dp" android:paddingHorizontal="12dp" android:layout_marginTop="4dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_rec_req" android:textColor="@color/accent" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.08" android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="OS" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_os_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_os_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Processor" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_proc_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_proc_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Memory" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_mem_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_mem_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Graphics" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_gfx_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_gfx_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_odd" android:paddingVertical="10dp" android:paddingHorizontal="12dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DirectX" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_dx_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_dx_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/table_row_even" android:paddingVertical="10dp" android:paddingHorizontal="12dp" android:layout_marginBottom="24dp"><TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Storage" android:textColor="@color/text_secondary" android:textSize="12sp"/><TextView android:id="@+id/tv_rec_store_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/><TextView android:id="@+id/tv_rec_store_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="N/A" android:textColor="@color/text_primary" android:textSize="12sp" android:layout_marginStart="8dp"/></LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
