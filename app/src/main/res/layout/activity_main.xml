<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_variant"
        app:title="CompareX"
        app:titleTextColor="@color/text_primary"/>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/primary_variant"
        android:gravity="center_vertical">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="@color/surface_variant"
            app:boxBackgroundColor="@color/surface"
            app:hintTextColor="@color/text_secondary"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_search"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="15sp"/>

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Onboarding banner: shown when user hasn't set their PC specs -->
    <LinearLayout
        android:id="@+id/layout_onboarding_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1F3A5F"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/msg_onboarding"
            android:textColor="@color/text_primary"
            android:textSize="12sp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_setup_spek"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/btn_fill_now"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            app:backgroundTint="@color/accent_dark"
            app:cornerRadius="6dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:visibility="gone"/>

        <!-- Skeleton loading list (replaces spinner) -->
        <LinearLayout
            android:id="@+id/layout_skeleton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:visibility="gone">
            <include layout="@layout/item_game_skeleton"/>
            <include layout="@layout/item_game_skeleton"/>
            <include layout="@layout/item_game_skeleton"/>
            <include layout="@layout/item_game_skeleton"/>
            <include layout="@layout/item_game_skeleton"/>
        </LinearLayout>

        <!-- Popular games state (shown when search is empty) -->
        <LinearLayout
            android:id="@+id/layout_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:visibility="visible">

            <!-- Header row -->
            <!-- ── History section (hidden when empty) ───────────────── -->
            <LinearLayout
                android:id="@+id/layout_history_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_recently_checked"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_history_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_clear"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:paddingHorizontal="4dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>

                <!-- Horizontal scroll history list -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    android:paddingBottom="16dp"
                    android:scrollbars="none"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:id="@+id/recycler_history_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recycler_history"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:nestedScrollingEnabled="false"/>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/surface_variant"
                    android:layout_marginBottom="12dp"/>

            </LinearLayout>

            <!-- ── Popular section header ────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_popular_games"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <ProgressBar
                    android:id="@+id/progress_popular"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:indeterminateTint="@color/accent"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- Popular games RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_popular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:paddingHorizontal="8dp"
                android:clipToPadding="false"/>

        </LinearLayout>

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/layout_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_empty_search"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/msg_no_results"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/msg_no_results_sub"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- Error state -->
        <LinearLayout
            android:id="@+id/layout_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_empty_error"/>

            <TextView
                android:id="@+id/tv_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/msg_error_generic"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retry"
                style="@style/Widget.CompareX.Button.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_retry"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </FrameLayout>

    <!-- Compare bar (muncul saat ≥1 game dipilih) -->
    <LinearLayout
        android:id="@+id/layout_compare_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_variant"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <!-- Tombol clear / hapus semua pilihan -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_selection"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_clear"
            android:textColor="@color/status_below"
            android:textSize="13sp"
            app:rippleColor="@color/status_below"
            app:cornerRadius="8dp"
            app:iconPadding="0dp"/>

        <!-- Label jumlah yang dipilih -->
        <TextView
            android:id="@+id/tv_selected_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_selected_games"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:gravity="center"/>

        <!-- Tombol bandingkan -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_compare"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/btn_compare"
            android:textSize="14sp"
            app:backgroundTint="@color/accent_dark"
            app:cornerRadius="8dp"/>

    </LinearLayout>

</LinearLayout>
