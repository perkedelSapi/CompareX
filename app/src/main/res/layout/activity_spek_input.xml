<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_variant"
        app:title="Spesifikasi PC / Laptop"
        app:titleTextColor="@color/text_primary"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header card dengan ilustrasi -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/table_section_header"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/accent_dark"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text=""
                        android:textSize="32sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/spek_header_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/spek_header_desc"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CPU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_cpu"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_cpu"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=""
                app:boxStrokeColor="@color/accent"
                app:boxBackgroundColor="@color/surface"
                app:hintTextColor="@color/text_secondary"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_secondary"
                android:layout_marginBottom="20dp">
                <AutoCompleteTextView
                    android:id="@+id/actv_cpu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:textColor="@color/text_primary"
                    android:dropDownHeight="240dp"
                    android:completionThreshold="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- GPU -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_gpu"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_gpu_sub"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_gpu"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint=""
                app:boxStrokeColor="@color/accent"
                app:boxBackgroundColor="@color/surface"
                app:hintTextColor="@color/text_secondary"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="@color/text_secondary"
                android:layout_marginBottom="20dp">
                <AutoCompleteTextView
                    android:id="@+id/actv_gpu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:textColor="@color/text_primary"
                    android:dropDownHeight="240dp"
                    android:completionThreshold="1"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- VRAM + RAM dalam satu baris -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <!-- VRAM -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_vram"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_vram"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        app:suffixText="GB"
                        app:suffixTextColor="@color/text_secondary"
                        app:boxStrokeColor="@color/accent"
                        app:boxBackgroundColor="@color/surface"
                        app:hintTextColor="@color/text_secondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_vram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_vram_note"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="3dp"/>
                </LinearLayout>

                <!-- RAM -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_ram"
                        android:textColor="@color/accent"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_ram"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        app:suffixText="GB"
                        app:suffixTextColor="@color/text_secondary"
                        app:boxStrokeColor="@color/accent"
                        app:boxBackgroundColor="@color/surface"
                        app:hintTextColor="@color/text_secondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_ram"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="3"
                            android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- RAM quick picks -->
            <com.google.android.material.chip.ChipGroup
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleLine="true"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">
                <com.google.android.material.chip.Chip android:id="@+id/chip_4gb"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="4 GB" app:chipBackgroundColor="@color/surface_variant"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_8gb"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="8 GB" app:chipBackgroundColor="@color/surface_variant"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_16gb"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="16 GB" app:chipBackgroundColor="@color/surface_variant"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_32gb"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="32 GB" app:chipBackgroundColor="@color/surface_variant"
                    android:textColor="@color/text_primary"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_64gb"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="64 GB" app:chipBackgroundColor="@color/surface_variant"
                    android:textColor="@color/text_primary"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_spek"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_save_spek"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/accent_dark"
                app:cornerRadius="10dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
