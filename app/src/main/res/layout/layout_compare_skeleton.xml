<?xml version="1.0" encoding="utf-8"?>
<!-- Skeleton loading state for CompareActivity -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skeleton_compare_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header title placeholder -->
        <View
            android:layout_width="220dp"
            android:layout_height="20dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/skeleton_block"
            android:tag="skeleton"/>
        <View
            android:layout_width="160dp"
            android:layout_height="13dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/skeleton_block"
            android:tag="skeleton"/>

        <!-- Game card 1 skeleton -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#21262D"
            app:cardCornerRadius="12dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">
                <!-- Cover -->
                <View
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:background="@drawable/skeleton_block"
                    android:tag="skeleton"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <View android:layout_width="match_parent" android:layout_height="16dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <View android:layout_width="140dp" android:layout_height="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <View android:layout_width="80dp" android:layout_height="12dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="14dp">
                        <View android:layout_width="60dp" android:layout_height="22dp"
                            android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                        <View android:layout_width="44dp" android:layout_height="22dp"
                            android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- VS divider skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#30363D"/>
            <View android:layout_width="36dp" android:layout_height="36dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#30363D"/>
        </LinearLayout>

        <!-- Game card 2 skeleton (same structure) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#21262D"
            app:cardCornerRadius="12dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">
                <View
                    android:layout_width="90dp"
                    android:layout_height="110dp"
                    android:background="@drawable/skeleton_block"
                    android:tag="skeleton"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">
                    <View android:layout_width="match_parent" android:layout_height="16dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <View android:layout_width="140dp" android:layout_height="16dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <View android:layout_width="80dp" android:layout_height="12dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="14dp">
                        <View android:layout_width="60dp" android:layout_height="22dp"
                            android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                        <View android:layout_width="44dp" android:layout_height="22dp"
                            android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Compare card skeleton -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#21262D"
            app:cardCornerRadius="16dp"
            app:strokeColor="#30363D"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <View android:layout_width="160dp" android:layout_height="17dp"
                    android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                <View android:layout_width="200dp" android:layout_height="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                <View android:layout_width="match_parent" android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/skeleton_block" android:tag="skeleton"/>
                <View android:layout_width="match_parent" android:layout_height="48dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/skeleton_block_round" android:tag="skeleton"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
