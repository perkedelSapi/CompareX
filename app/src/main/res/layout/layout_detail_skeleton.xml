<?xml version="1.0" encoding="utf-8"?>
<!-- Skeleton loading state for GameDetailActivity.
     Mirrors the real content structure: hero image → info card → compat card → AI card -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skeleton_detail_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero image placeholder -->
        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:tag="skeleton"
            android:background="@drawable/skeleton_block"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Game title line 1 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:tag="skeleton"
                android:background="@drawable/skeleton_block"/>

            <!-- Game title line 2 (shorter) -->
            <View
                android:layout_width="200dp"
                android:layout_height="22dp"
                android:layout_marginTop="8dp"
                android:tag="skeleton"
                android:background="@drawable/skeleton_block"/>

            <!-- Rating row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <View
                    android:layout_width="100dp"
                    android:layout_height="14dp"
                    android:tag="skeleton"
                    android:background="@drawable/skeleton_block"/>

                <View
                    android:layout_width="36dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:tag="skeleton"
                    android:background="@drawable/skeleton_block_round"/>
            </LinearLayout>

            <!-- Info card skeleton -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#21262D"
                app:cardCornerRadius="12dp"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 4 info rows -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                            android:tag="skeleton"
                        <View android:layout_width="100dp" android:layout_height="12dp" android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1"
                            android:tag="skeleton"
                            android:layout_marginStart="12dp" android:background="@drawable/skeleton_block"/>
                    </LinearLayout>
                        android:tag="skeleton"
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#30363D"/>
            android:tag="skeleton"

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                            android:tag="skeleton"
                        <View android:layout_width="100dp" android:layout_height="12dp" android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1"
                            android:tag="skeleton"
                            android:layout_marginStart="12dp" android:background="@drawable/skeleton_block"/>
                    </LinearLayout>
                        android:tag="skeleton"
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#30363D"/>
            android:tag="skeleton"

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                            android:tag="skeleton"
                        <View android:layout_width="100dp" android:layout_height="12dp" android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1"
                            android:tag="skeleton"
                            android:layout_marginStart="12dp" android:background="@drawable/skeleton_block"/>
                    </LinearLayout>
                        android:tag="skeleton"
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#30363D"/>
            android:tag="skeleton"

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:paddingVertical="8dp" android:gravity="center_vertical">
                            android:tag="skeleton"
                        <View android:layout_width="100dp" android:layout_height="12dp" android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="0dp" android:layout_height="12dp" android:layout_weight="1"
                            android:tag="skeleton"
                            android:layout_marginStart="12dp" android:background="@drawable/skeleton_block"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Compatibility card skeleton -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#21262D"
                app:cardCornerRadius="12dp"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Label -->
                    <View android:layout_width="180dp" android:layout_height="11dp"
                        android:tag="skeleton"
                        android:background="@drawable/skeleton_block"/>

                    <!-- Spek user text -->
                    <View android:layout_width="match_parent" android:layout_height="11dp"
                        android:tag="skeleton"
                        android:layout_marginTop="10dp" android:background="@drawable/skeleton_block"/>

                    <!-- Progress bar -->
                    <View android:layout_width="match_parent" android:layout_height="8dp"
                        android:tag="skeleton"
                        android:layout_marginTop="14dp" android:background="@drawable/skeleton_block_round"/>

                    <!-- Score row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="12dp">
                        <View android:layout_width="0dp" android:layout_height="18dp"
                            android:tag="skeleton"
                            android:layout_weight="1" android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="50dp" android:layout_height="24dp"
                            android:tag="skeleton"
                            android:layout_marginStart="12dp" android:background="@drawable/skeleton_block"/>
                    </LinearLayout>

                    <!-- Setting badge -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="10dp" android:gravity="center_vertical">
                        <View android:layout_width="140dp" android:layout_height="12dp"
                            android:tag="skeleton"
                            android:background="@drawable/skeleton_block"/>
                        <View android:layout_width="60dp" android:layout_height="26dp"
                            android:tag="skeleton"
                            android:layout_marginStart="8dp" android:background="@drawable/skeleton_block_round"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI card skeleton -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#21262D"
                app:cardCornerRadius="16dp"
                app:strokeColor="#30363D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <View android:layout_width="160dp" android:layout_height="17dp"
                                android:tag="skeleton"
                                android:background="@drawable/skeleton_block"/>
                            <View android:layout_width="200dp" android:layout_height="12dp"
                                android:tag="skeleton"
                                android:layout_marginTop="6dp" android:background="@drawable/skeleton_block"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Spek monospace box -->
                    <View android:layout_width="match_parent" android:layout_height="56dp"
                        android:tag="skeleton"
                        android:layout_marginTop="12dp" android:background="@drawable/skeleton_block"/>

                    <!-- Button placeholder -->
                    <View android:layout_width="match_parent" android:layout_height="48dp"
                        android:tag="skeleton"
                        android:layout_marginTop="14dp" android:background="@drawable/skeleton_block_round"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Description section skeleton -->
            <View android:layout_width="100dp" android:layout_height="11dp"
                android:tag="skeleton"
                android:layout_marginTop="24dp" android:background="@drawable/skeleton_block"/>

            <View android:layout_width="match_parent" android:layout_height="12dp"
                android:tag="skeleton"
                android:layout_marginTop="12dp" android:background="@drawable/skeleton_block"/>
            <View android:layout_width="match_parent" android:layout_height="12dp"
                android:tag="skeleton"
                android:layout_marginTop="8dp" android:background="@drawable/skeleton_block"/>
            <View android:layout_width="240dp" android:layout_height="12dp"
                android:tag="skeleton"
                android:layout_marginTop="8dp" android:background="@drawable/skeleton_block"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
